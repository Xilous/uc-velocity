# UC Velocity ERP - Frontend Environment Variables
# Copy this file to .env and fill in the values
# Note: These are injected at BUILD TIME, not runtime

# Backend API URL (optional)
# Defaults to http://localhost:8000 for local development
# Set this to your deployed backend URL for production builds
# VITE_API_BASE=https://your-backend.up.railway.app

# Clerk Authentication (required)
# Get your publishable key from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
